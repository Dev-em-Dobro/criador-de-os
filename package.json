{
  "name": "criador-de-os",
  "private": true,
  "version": "0.0.0",
  "description": "Fábrica de OSs sob medida para clientes — monorepo config-driven (core + blocks + apps).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "create-client": "pnpm --filter @os/scaffolder exec tsx src/index.ts",
    "os": "pnpm --filter @os/scaffolder exec tsx src/index.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.4",
    "typescript": "~5.9.3"
  }
}
