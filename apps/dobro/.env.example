# ============================================
# @app/dobro — variáveis de ambiente
# Copie para .env (NÃO commitar). Segredos ficam SÓ no servidor.
# REGRA DE OURO: nenhum segredo com prefixo VITE_ (o Vite injeta VITE_* no bundle).
# ============================================

# --- Neon (Postgres) OWNER — usado SÓ por scripts admin (migrate/seed/grants) ---
# Neste monorepo, a connection string canônica é NEON_DATABASE_URL, definida no
# .env da RAIZ do repo (herdada automaticamente pela API — ver api/env.ts).
# Se quiser sobrescrever por app, defina DATABASE_URL aqui (sem prefixo VITE_).
# ⚠️ OWNER lê/escreve/DROP tudo — o RUNTIME da API usa os roles abaixo, não este.
NEON_DATABASE_URL=
DATABASE_URL=

# --- Roles de MENOR PRIVILÉGIO para a API (Fase 3 hardening — doc 05, §4/§6) ---
# A API NÃO deve conectar como owner. Dois caminhos, dois roles:
#   AUTH_DATABASE_URL  → role app_auth  (R/W só nas tabelas do Better Auth)
#   QUERY_DATABASE_URL → role app_query (SELECT só nas views v_*)
# Provisione cada role no Console Neon (ou `ALTER ROLE app_auth LOGIN PASSWORD '...'`)
# e cole a connection string dele aqui. Aplique os privilégios e prove com:
#   pnpm db:migrate         # roda db/grants.sql (idempotente)
#   pnpm db:verify-grants   # prova o isolamento por caminho
# Se vazios, a API cai no fallback OWNER (com WARN) — aceitável só em DEV; em
# produção, defina AMBOS para ativar a defesa no nível do banco.
AUTH_DATABASE_URL=
QUERY_DATABASE_URL=

# --- Better Auth (self-hosted) — server-side ---
# BETTER_AUTH_SECRET assina as sessões (obrigatório). Gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Origem pública do app (Vite dev = 5173). Não é segredo.
BETTER_AUTH_URL=http://localhost:5173

# --- API local (dev) ---
# Porta da API Hono servida por api/server.ts; o Vite faz proxy de /api → esta porta.
API_PORT=8787
