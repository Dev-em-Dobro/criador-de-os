# ============================================
# @app/dobro — variáveis de ambiente
# Copie para .env (NÃO commitar). Segredos ficam SÓ no servidor.
# REGRA DE OURO: nenhum segredo com prefixo VITE_ (o Vite injeta VITE_* no bundle).
# ============================================

# --- Neon (Postgres) OWNER — usado SÓ por scripts admin (migrate/seed/grants) ---
# Neste monorepo, a connection string canônica é NEON_DATABASE_URL, definida no
# .env da RAIZ do repo (herdada automaticamente pela API — ver api/env.ts).
# Se quiser sobrescrever por app, defina DATABASE_URL aqui (sem prefixo VITE_).
# ⚠️ OWNER lê/escreve/DROP tudo — o RUNTIME da API usa os roles abaixo, não este.
NEON_DATABASE_URL=
DATABASE_URL=

# --- Roles de MENOR PRIVILÉGIO para a API (Fase 3 hardening — doc 05, §4/§6) ---
# A API NÃO deve conectar como owner. Dois caminhos, dois roles:
#   AUTH_DATABASE_URL  → role app_auth  (R/W só nas tabelas do Better Auth)
#   QUERY_DATABASE_URL → role app_query (SELECT só nas views v_*)
# Provisione cada role no Console Neon (ou `ALTER ROLE app_auth LOGIN PASSWORD '...'`)
# e cole a connection string dele aqui. Aplique os privilégios e prove com:
#   pnpm db:migrate         # roda db/grants.sql (idempotente)
#   pnpm db:verify-grants   # prova o isolamento por caminho
# Se vazios, a API cai no fallback OWNER (com WARN) — aceitável só em DEV; em
# produção, defina AMBOS para ativar a defesa no nível do banco.
AUTH_DATABASE_URL=
QUERY_DATABASE_URL=
#   INGEST_DATABASE_URL → role app_ingest (INSERT só na tabela `referencias`),
#   usado pelo webhook do Telegram. Vazio = fallback OWNER (WARN) — só em DEV.
INGEST_DATABASE_URL=
#   CONTENT_DATABASE_URL → role app_content (SELECT/INSERT/UPDATE/DELETE só em
#   `conteudo_posts`), usado pelas rotas /api/conteudo (o criador cadastra/edita
#   o cronograma pela tela). Vazio = fallback OWNER (WARN) — só em DEV.
CONTENT_DATABASE_URL=

# --- Ingestão do Telegram (webhook de referências) ---
# TELEGRAM_BOT_TOKEN: token do bot (crie um no @BotFather). Opcional — sem ele o
#   webhook ainda grava, só não responde no chat.
# TELEGRAM_WEBHOOK_SECRET: string forte que autentica o webhook. O setWebhook a
#   configura e o Telegram a devolve em todo request; sem ela o endpoint dá 401.
#   Gere: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- IA (pipeline de conteúdo referência→rascunho) ---
# ANTHROPIC_API_KEY: chave da agência (fallback) / BYOK. Usada server-side pelo
# script `conteudo:processar`. Sem ela, o pipeline sai limpo (não processa).
ANTHROPIC_API_KEY=

# --- Instagram (conteúdo real das referências) ---
# O pipeline busca legenda/formato/métricas do post da referência antes de gerar.
# PRIMÁRIO: yt-dlp (GRÁTIS, sem login) — se estiver no PATH, é usado automaticamente.
#   YTDLP_PATH (opcional) aponta pro binário caso não esteja no PATH.
# FALLBACK: Apify (pago) — só é usado se o yt-dlp falhar.
#   APIFY_TOKEN (apify.com → Settings → Integrations) + APIFY_IG_ACTOR (opcional,
#   default apify~instagram-scraper).
YTDLP_PATH=
APIFY_TOKEN=
APIFY_IG_ACTOR=

# --- Better Auth (self-hosted) — server-side ---
# BETTER_AUTH_SECRET assina as sessões (obrigatório). Gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Origem pública do app (Vite dev = 5173). Não é segredo.
BETTER_AUTH_URL=http://localhost:5173

# --- API local (dev) ---
# Porta da API Hono servida por api/server.ts; o Vite faz proxy de /api → esta porta.
API_PORT=8787
