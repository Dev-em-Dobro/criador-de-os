{
  "name": "@app/dobro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/server.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:verify": "tsx db/verify.ts",
    "db:verify-grants": "tsx db/verify-grants.ts",
    "db:provision-roles": "tsx db/provision-roles.ts",
    "db:setup": "pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "test:smoke": "tsx server/scripts/smoke-e2e.ts",
    "test:telegram": "tsx server/scripts/smoke-telegram.ts",
    "conteudo:processar": "tsx server/scripts/processar-referencias.ts",
    "referencias:list": "tsx server/scripts/list-referencias.ts",
    "referencias:reset": "tsx server/scripts/reset-referencia.ts",
    "ig:fetch": "tsx server/scripts/test-ig-fetch.ts",
    "telegram:set-webhook": "tsx server/scripts/telegram-set-webhook.ts",
    "telegram:delete-webhook": "tsx server/scripts/telegram-delete-webhook.ts",
    "telegram:webhook-info": "tsx server/scripts/telegram-webhook-info.ts",
    "auth:create-user": "tsx server/scripts/create-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@hono/node-server": "^2.0.8",
    "@neondatabase/serverless": "^1.1.0",
    "@os/blocks": "workspace:*",
    "@os/core": "workspace:*",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
