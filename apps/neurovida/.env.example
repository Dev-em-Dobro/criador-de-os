# ============================================
# @app/neurovida — variáveis de ambiente
# Copie para .env (NÃO commitar). Segredos ficam SÓ no servidor.
# REGRA DE OURO: nenhum segredo com prefixo VITE_ (o Vite injeta VITE_* no bundle).
# ============================================

# --- Claude API (Anthropic) — usada SÓ pela API server-side (api/) ---
# Gere uma key em https://console.anthropic.com/ (Settings → API Keys).
# Necessária para o "Estúdio IA" (gerador de carrossel). Cada geração consome
# tokens (custo por uso). Nunca vai para o bundle do front.
ANTHROPIC_API_KEY=

# Porta local da API Hono (dev); o Vite faz proxy de /api → esta porta.
NEUROVIDA_API_PORT=8788
