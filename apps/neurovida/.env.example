# ============================================
# @app/neurovida — variáveis de ambiente
# Copie para .env (NÃO commitar). Segredos ficam SÓ no servidor.
# REGRA DE OURO: nenhum segredo com prefixo VITE_ (o Vite injeta VITE_* no bundle).
# ============================================

# --- Neon (Postgres) — o PRÓPRIO banco do neurovida (isolamento por cliente) ---
# OWNER (só scripts admin: migrate/grants/provision). ⚠️ lê/escreve/DROP tudo.
# Este app carrega SÓ este .env — NÃO herda o NEON_DATABASE_URL da raiz (que é de
# outro cliente). Cada cliente = 1 projeto Neon.
DATABASE_URL=
# Role de menor privilégio do RUNTIME (Better Auth + /api/settings). Gerado por
# `pnpm db:migrate && pnpm db:provision-roles` (grava aqui). Vazio = fallback OWNER (WARN) — só DEV.
AUTH_DATABASE_URL=

# --- Better Auth (self-hosted) — server-side ---
# Assina as sessões. Gere: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# --- Configurações do cliente (BYOK) — cifra em repouso ---
# Chave que CRIPTOGRAFA os segredos que o cliente salva em Configurações (ex.: a
# chave da Anthropic dele). NÃO é a chave do cliente. Opcional: se vazia, deriva
# do BETTER_AUTH_SECRET. Se definir, use um valor aleatório forte e ESTÁVEL
# (trocar invalida os segredos já cifrados).
SETTINGS_ENC_KEY=

# --- Claude API (Anthropic) — FALLBACK de DEV (chave da agência) ---
# Opcional. O modelo primário é BYOK: o cliente cola a PRÓPRIA chave em
# Configurações (guardada cifrada no Neon). Esta serve só de fallback em DEV
# enquanto não há chave do cliente. Nunca vai para o bundle do front.
ANTHROPIC_API_KEY=

# Porta local da API Hono (dev); o Vite faz proxy de /api → esta porta.
NEUROVIDA_API_PORT=8788
